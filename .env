# Pihole config
TZ=America/Denver
DNS_LISTENINGMODE='all'
DHCP_ACTIVE=false
DHCP_IPV6_ACTIVE=false
NTP_IPV4_ACTIVE=false
NTP_IPV6_ACTIVE=false
NTP_SYNC_ACTIVE=false
# Optional: only used if FTLCONF_webserver_api_password is uncommented in
# docker-compose.yml. Recommended alternative: run
# `docker exec pihole pihole setpassword 'mypassword'` once instead (see README).
#WEBSERVER_PASSWORD=''
